# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/zion_freelance?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
# Set to true behind reverse proxies (e.g. Vercel) if you see callback URL issues.
# AUTH_TRUST_HOST="true"

# Email (production): https://resend.com — without this, dev mode logs reset links to the console only.
RESEND_API_KEY=""
EMAIL_FROM="Zion TeCHer <noreply@yourdomain.com>"
