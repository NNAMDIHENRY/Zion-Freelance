generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CLIENT
  FREELANCER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  CLOSED
}

enum ProposalStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  PENDING
  ACTIVE
  COMPLETED
  TERMINATED
  DISPUTED
}

enum EscrowStatus {
  AWAITING_FUNDING
  FUNDED
  PARTIALLY_RELEASED
  RELEASED
  REFUNDED
  DISPUTED
}

enum EscrowRecordType {
  FUND
  RELEASE
  PARTIAL_RELEASE
  REFUND
  ADJUSTMENT
  DISPUTE_OPENED
  DISPUTE_RESOLVED
}

enum TransactionType {
  DEPOSIT
  PAYMENT
  WITHDRAWAL
  ESCROW_HOLD
  ESCROW_RELEASE
  ESCROW_REFUND
  FEE
  ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  INTERNAL
  STRIPE
  PAYPAL
  OTHER
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum NotificationType {
  MESSAGE
  PROPOSAL
  CONTRACT
  PAYMENT
  ESCROW
  WITHDRAWAL
  REVIEW
  SYSTEM
}

enum FilePurpose {
  AVATAR
  PORTFOLIO
  PROJECT_BRIEF
  PROPOSAL_ATTACHMENT
  MESSAGE_ATTACHMENT
  CONTRACT_DOCUMENT
  VERIFICATION
  WITHDRAWAL_PROOF
  OTHER
}

enum ReviewSubject {
  CLIENT_TO_FREELANCER
  FREELANCER_TO_CLIENT
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String
  role         Role      @default(CLIENT)
  emailVerified DateTime?
  imageFileId  String?   @unique
  imageFile    FileUpload? @relation("UserAvatar", fields: [imageFileId], references: [id])

  freelancerProfile FreelancerProfile?
  clientProfile     ClientProfile?

  wallet Wallet?

  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]               @relation("MessageSender")
  notifications            Notification[]
  fileUploads              FileUpload[]            @relation("UploadedBy")

  reviewsWritten Review[] @relation("ReviewAuthor")
  reviewsAbout   Review[] @relation("ReviewSubject")

  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, createdAt])
}

/// One-time password reset tokens (store hash only; raw token sent by email).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([tokenHash])
}

model FreelancerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  headline  String?
  bio       String?
  hourlyRate Decimal? @db.Decimal(12, 2)
  isPublic   Boolean  @default(true)

  ratingAverage Decimal @default(0) @db.Decimal(4, 2)
  ratingCount   Int     @default(0)

  skills          FreelancerSkill[]
  proposals       Proposal[]
  reviewsReceived Review[]          @relation("ReviewFreelancerProfile")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublic, ratingAverage])
}

model ClientProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String?
  websiteUrl  String?

  projects        Project[]
  reviewsReceived Review[]  @relation("ReviewClientProfile")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Taxonomy
// ---------------------------------------------------------------------------

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Skill {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  freelancers FreelancerSkill[]
  projects    ProjectSkill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FreelancerSkill {
  id                  String @id @default(cuid())
  freelancerProfileId String
  skillId             String
  yearsExperience     Int?
  proficiency         Int? // 1–5, optional

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  skill             Skill             @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([freelancerProfileId, skillId])
  @@index([skillId])
}

model ProjectSkill {
  id        String @id @default(cuid())
  projectId String
  skillId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([projectId, skillId])
  @@index([skillId])
}

// ---------------------------------------------------------------------------
// Marketplace workflow
// ---------------------------------------------------------------------------

model Project {
  id          String        @id @default(cuid())
  title       String
  description String
  budgetMin   Decimal?      @db.Decimal(19, 4)
  budgetMax   Decimal?      @db.Decimal(19, 4)
  currency    String        @default("USD")
  deadline    DateTime?
  status      ProjectStatus @default(DRAFT)

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  proposals Proposal[]
  contract  Contract?

  skills       ProjectSkill[]
  attachments  FileUpload[]   @relation("ProjectFiles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, status])
  @@index([categoryId, status])
  @@index([status, createdAt])
}

model Proposal {
  id             String         @id @default(cuid())
  proposedPrice  Decimal        @db.Decimal(19, 4)
  currency       String         @default("USD")
  coverLetter    String
  deliveryDays   Int?
  status         ProposalStatus @default(PENDING)
  withdrawnAt    DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  freelancerId String
  freelancer   FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  contract Contract?

  attachments FileUpload[] @relation("ProposalFiles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, freelancerId])
  @@index([projectId, status])
  @@index([freelancerId, status])
}

model Contract {
  id           String         @id @default(cuid())
  status       ContractStatus @default(PENDING)
  agreedAmount Decimal        @db.Decimal(19, 4)
  currency     String         @default("USD")
  startsAt     DateTime?
  endsAt       DateTime?

  projectId String @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  proposalId String @unique
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  escrow    Escrow?
  payments  Payment[]
  reviews   Review[]
  documents FileUpload[] @relation("ContractFiles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Financials
// ---------------------------------------------------------------------------

model Wallet {
  id       String  @id @default(cuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency String  @default("USD")
  balance  Decimal @default(0) @db.Decimal(19, 4)

  transactions        Transaction[]
  paymentsAsPayer     Payment[]           @relation("PayerWallet")
  paymentsAsPayee     Payment[]           @relation("PayeeWallet")
  withdrawalRequests  WithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(19, 4)
  currency    String          @default("USD")
  description String?
  idempotencyKey String?      @unique

  balanceAfter Decimal? @db.Decimal(19, 4)

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  paymentId             String?
  payment               Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  withdrawalRequestId   String?
  withdrawalRequest     WithdrawalRequest? @relation(fields: [withdrawalRequestId], references: [id], onDelete: SetNull)
  escrowRecordId        String?            @unique
  escrowRecord          EscrowRecord?       @relation(fields: [escrowRecordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([type, createdAt])
}

/// Business-level payment (gateway / invoice), linked to ledger `Transaction` rows.
model Payment {
  id            String          @id @default(cuid())
  amount        Decimal         @db.Decimal(19, 4)
  currency      String          @default("USD")
  status        PaymentStatus   @default(PENDING)
  provider      PaymentProvider @default(INTERNAL)
  providerRef   String?
  failureReason String?

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  payerWalletId String?
  payerWallet   Wallet? @relation("PayerWallet", fields: [payerWalletId], references: [id], onDelete: SetNull)
  payeeWalletId String?
  payeeWallet   Wallet? @relation("PayeeWallet", fields: [payeeWalletId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([contractId])
  @@index([provider, providerRef])
}

model WithdrawalRequest {
  id            String            @id @default(cuid())
  amount        Decimal           @db.Decimal(19, 4)
  currency      String            @default("USD")
  status        WithdrawalStatus  @default(PENDING)
  payoutMethod  String // e.g. bank_transfer, mobile_money
  payoutDetails Json? // masked destination metadata (never store full PAN)

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  attachments  FileUpload[] @relation("WithdrawalFiles")

  reviewedAt DateTime?
  reviewNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletId, status])
  @@index([status, createdAt])
}

model Escrow {
  id              String       @id @default(cuid())
  contractId      String       @unique
  contract        Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  status          EscrowStatus @default(AWAITING_FUNDING)
  fundedAmount    Decimal      @default(0) @db.Decimal(19, 4)
  releasedAmount  Decimal      @default(0) @db.Decimal(19, 4)
  currency        String       @default("USD")
  fundedAt        DateTime?
  fullyReleasedAt DateTime?

  records EscrowRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// Append-only style ledger lines for escrow lifecycle (pairs with `Transaction` when money moves).
model EscrowRecord {
  id       String           @id @default(cuid())
  type     EscrowRecordType
  amount   Decimal          @db.Decimal(19, 4)
  currency String           @default("USD")
  note     String?

  escrowId String
  escrow   Escrow @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  transaction Transaction?

  createdAt DateTime @default(now())

  @@index([escrowId, createdAt])
  @@index([type, createdAt])
}

// ---------------------------------------------------------------------------
// Social & comms
// ---------------------------------------------------------------------------

model Review {
  id      String        @id @default(cuid())
  rating  Int // 1–5 enforced in app layer or DB check
  comment String?
  subject ReviewSubject

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  authorUserId String
  authorUser   User   @relation("ReviewAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  subjectUserId String
  subjectUser   User   @relation("ReviewSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)

  freelancerProfileId String?
  freelancerProfile   FreelancerProfile? @relation("ReviewFreelancerProfile", fields: [freelancerProfileId], references: [id], onDelete: SetNull)
  clientProfileId     String?
  clientProfile       ClientProfile?     @relation("ReviewClientProfile", fields: [clientProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, authorUserId])
  @@index([subjectUserId, createdAt])
  @@index([freelancerProfileId])
  @@index([clientProfileId])
}

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  title   String
  body    String
  read    Boolean          @default(false)
  readAt  DateTime?
  data    Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([createdAt])
}

model Conversation {
  id       String @id @default(cuid())
  subject  String?
  projectId String?

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  muted          Boolean   @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId, conversationId])
}

model Message {
  id        String @id @default(cuid())
  content   String
  senderId  String
  sender    User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  replyToId String?
  replyTo   Message?  @relation("MessageThread", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageThread")

  readAt DateTime?

  attachments FileUpload[] @relation("MessageFiles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

// ---------------------------------------------------------------------------
// Files
// ---------------------------------------------------------------------------

model FileUpload {
  id           String      @id @default(cuid())
  purpose      FilePurpose @default(OTHER)
  storageKey   String      @unique
  originalName String
  mimeType     String
  sizeBytes    Int
  checksum     String?

  uploadedByUserId String
  uploadedBy       User   @relation("UploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  userAvatar User? @relation("UserAvatar")

  projectId String?
  project   Project? @relation("ProjectFiles", fields: [projectId], references: [id], onDelete: Cascade)

  proposalId String?
  proposal   Proposal? @relation("ProposalFiles", fields: [proposalId], references: [id], onDelete: Cascade)

  contractId String?
  contract   Contract? @relation("ContractFiles", fields: [contractId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation("MessageFiles", fields: [messageId], references: [id], onDelete: Cascade)

  withdrawalRequestId String?
  withdrawalRequest   WithdrawalRequest? @relation("WithdrawalFiles", fields: [withdrawalRequestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([uploadedByUserId, createdAt])
  @@index([projectId])
  @@index([messageId])
}
